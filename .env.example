# 项目环境变量模板
# 说明：
# 1. 本模板只配置提供商与端点，不在这里写具体模型名。
# 2. VLM/LLM 的模型名由前端页面手动填写。
# 3. VLM 与 LLM 可以来自不同厂商。
# 4. 如果某个提供商不需要 API Key，则对应的 API_KEY_ENV_NAME 留空即可。


# =========================
# API Key 区
# =========================

# DashScope 示例
# DASHSCOPE_API_KEY=your_dashscope_api_key

# OpenAI 兼容网关示例
# OPENAI_API_KEY=your_openai_api_key


# =========================
# VLM 提供商配置
# =========================

# 这里列出所有允许在前端选择的视觉提供商 ID。
VLM_PROVIDER_IDS=dashscope_vl,ollama_vl

# DashScope 视觉端点
VLM_PROVIDER_DASHSCOPE_VL_LABEL=DashScope 视觉
VLM_PROVIDER_DASHSCOPE_VL_TYPE=dashscope
VLM_PROVIDER_DASHSCOPE_VL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VLM_PROVIDER_DASHSCOPE_VL_API_KEY_ENV_NAME=DASHSCOPE_API_KEY
VLM_PROVIDER_DASHSCOPE_VL_ENABLED=1

# Ollama 视觉端点
VLM_PROVIDER_OLLAMA_VL_LABEL=Ollama 视觉
VLM_PROVIDER_OLLAMA_VL_TYPE=ollama
VLM_PROVIDER_OLLAMA_VL_BASE_URL=http://127.0.0.1:11434
VLM_PROVIDER_OLLAMA_VL_API_KEY_ENV_NAME=
VLM_PROVIDER_OLLAMA_VL_ENABLED=1


# =========================
# LLM 提供商配置
# =========================

# 这里列出所有允许在前端选择的文本提供商 ID。
LLM_PROVIDER_IDS=lmstudio_llm,dashscope_llm

# LM Studio 文本端点
LLM_PROVIDER_LMSTUDIO_LLM_LABEL=LM Studio 文本
LLM_PROVIDER_LMSTUDIO_LLM_TYPE=lm_studio
LLM_PROVIDER_LMSTUDIO_LLM_BASE_URL=http://127.0.0.1:1234/v1
LLM_PROVIDER_LMSTUDIO_LLM_API_KEY_ENV_NAME=
LLM_PROVIDER_LMSTUDIO_LLM_ENABLED=1

# DashScope 文本端点
LLM_PROVIDER_DASHSCOPE_LLM_LABEL=DashScope 文本
LLM_PROVIDER_DASHSCOPE_LLM_TYPE=dashscope
LLM_PROVIDER_DASHSCOPE_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_PROVIDER_DASHSCOPE_LLM_API_KEY_ENV_NAME=DASHSCOPE_API_KEY
LLM_PROVIDER_DASHSCOPE_LLM_ENABLED=1


# =========================
# 自定义 OpenAI 兼容端点示例
# =========================

# 如果你要接入自定义兼容端点，可以按下面格式新增 provider。
# 注意：新增后要把 provider_id 加到上面的 PROVIDER_IDS 中。

# VLM_PROVIDER_IDS=dashscope_vl,ollama_vl,my_gateway_vl
# VLM_PROVIDER_MY_GATEWAY_VL_LABEL=自定义视觉网关
# VLM_PROVIDER_MY_GATEWAY_VL_TYPE=openai_compatible
# VLM_PROVIDER_MY_GATEWAY_VL_BASE_URL=http://127.0.0.1:8000/v1
# VLM_PROVIDER_MY_GATEWAY_VL_API_KEY_ENV_NAME=OPENAI_API_KEY
# VLM_PROVIDER_MY_GATEWAY_VL_ENABLED=1

# LLM_PROVIDER_IDS=lmstudio_llm,dashscope_llm,my_gateway_llm
# LLM_PROVIDER_MY_GATEWAY_LLM_LABEL=自定义文本网关
# LLM_PROVIDER_MY_GATEWAY_LLM_TYPE=openai_compatible
# LLM_PROVIDER_MY_GATEWAY_LLM_BASE_URL=http://127.0.0.1:8000/v1
# LLM_PROVIDER_MY_GATEWAY_LLM_API_KEY_ENV_NAME=OPENAI_API_KEY
# LLM_PROVIDER_MY_GATEWAY_LLM_ENABLED=1
